# Copy this file to `.env` and adjust values as needed.
# Django will read these via os.environ in config/settings.py.

# SECRET_KEY — generate a real one for production with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-change-me-in-production

DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Default DB is SQLite so the project boots with zero external services.
# To use PostgreSQL (recommended for the assessment's `psycopg2-binary` dep):
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/artikate
DATABASE_URL=sqlite:///db.sqlite3

# Redis — used by Celery (broker + result backend) AND by the Section 2
# Token Bucket rate limiter.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
